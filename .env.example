# Bitcoin Quantum RPC Configuration
RPC_HOST=127.0.0.1
RPC_PORT=18334
RPC_USER=btqrpc
RPC_PASS=your_rpc_password_here
RPC_WALLET=faucet

# Faucet Configuration
FAUCET_ADDRESS=your_main_faucet_address_here
FAUCET_FEE=0.0001
REWARD_PER_MINUTE=0.01
MIN_CLAIM=0.01
DIFFICULTY_BASE=4
DIFFICULTY_STEP_SECONDS=300
ACTIVE_SHARE_WINDOW=30
SESSION_EXPIRE_SECONDS=3600

# Security
IP_SALT=generate_random_string_here

# hCaptcha (optional - leave empty to disable)
# Get your keys at https://www.hcaptcha.com/
HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# Server
PORT=3000
